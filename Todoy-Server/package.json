{
  "name": "todoyserver",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --watch local-server --exec ts-node -r dotenv/config local-server/server.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "typecheck": "tsc --noEmit",
    "getTasks": "ts-node -e \"require('./src/services/tasks/handler').handler(require('./src/services/tasks/events/getTasks.json'), {})\""
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1007.0",
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "aws-cdk-lib": "2.241.0",
    "constructs": "^10.5.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.3",
    "express": "^4.19.2",
    "pg": "^8.20.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.18.0",
    "nodemon": "^3.0.3"
  }
}
